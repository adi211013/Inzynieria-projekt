generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GoalStatus {
  in_progress
  completed
  failed

  @@map("goal_status")
}

model users {
  user_id               Int       @id @default(autoincrement())
  username              String    @unique @db.VarChar(100)
  email                 String    @unique @db.VarChar(255)
  password              String    @db.VarChar(255)
  display_name          String?   @db.VarChar(100)
  theme                 String    @default("light") @db.VarChar(20)
  timezone              String    @default("Europe/Warsaw") @db.VarChar(64)
  language              String    @default("pl") @db.VarChar(8)
  notifications_enabled Boolean   @default(false)
  reminder_time         String?   @db.VarChar(5)
  created_at            DateTime? @default(now()) @db.Timestamp(6)

  habits     habits[]
  habit_logs habit_logs[]
  goals      goals[]
  goal_logs  goal_logs[]
}

model habits {
  habit_id              Int       @id @default(autoincrement())
  user_id               Int
  name                  String    @db.VarChar(255)
  description           String?
  category              String?   @db.VarChar(50)
  icon                  String?   @db.VarChar(50)
  color                 String?   @db.VarChar(20)
  frequency             Json
  target_count          Decimal?  @db.Decimal(10, 2)
  unit                  String?   @db.VarChar(30)
  notifications_enabled Boolean   @default(false)
  reminder_time         String?   @db.VarChar(5)
  created_at            DateTime? @default(now()) @db.Timestamp(6)
  is_active             Boolean?  @default(true)

  users      users        @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  habit_logs habit_logs[]
  goals      goals[]
}

model habit_logs {
  habit_log_id Int      @id @default(autoincrement())
  user_id      Int
  habit_id     Int
  value        Decimal? @db.Decimal(10, 2)
  date         DateTime @db.Date
  note         String?
  created_at   DateTime @default(now()) @db.Timestamp(6)

  users  users  @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  habits habits @relation(fields: [habit_id], references: [habit_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([habit_id, date])
}

model goals {
  goal_id               Int        @id @default(autoincrement())
  user_id               Int
  habit_id              Int
  name                  String     @db.VarChar(255)
  description           String?
  category              String?    @db.VarChar(50)
  icon                  String?    @db.VarChar(50)
  color                 String?    @db.VarChar(20)
  frequency             Json
  target_days           Int
  status                GoalStatus @default(in_progress)
  notifications_enabled Boolean    @default(false)
  reminder_time         String?    @db.VarChar(5)
  deadline              DateTime?  @db.Date
  created_at            DateTime?  @default(now()) @db.Timestamp(6)
  is_active             Boolean    @default(true)

  users     users       @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  habits    habits      @relation(fields: [habit_id], references: [habit_id], onDelete: Cascade, onUpdate: NoAction)
  goal_logs goal_logs[]
}

model goal_logs {
  goal_log_id Int      @id @default(autoincrement())
  user_id     Int
  goal_id     Int
  completed   Boolean  @default(true)
  date        DateTime @db.Date
  note        String?
  created_at  DateTime @default(now()) @db.Timestamp(6)

  users users @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  goals goals @relation(fields: [goal_id], references: [goal_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([goal_id, date])
}

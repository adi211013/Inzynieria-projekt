generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  user_id    Int          @id @default(autoincrement())
  username   String       @unique @db.VarChar(100)
  email      String       @unique @db.VarChar(255)
  password   String       @db.VarChar(255)
  created_at DateTime?    @default(now()) @db.Timestamp(6)
  habits     habits[]
  habit_logs habit_logs[]
  goals      goals[]
  goal_logs  goal_logs[]
}

model habits {
  habit_id    Int          @id @default(autoincrement())
  user_id     Int
  name        String       @db.VarChar(255)
  description String?
  frequency   String?      @db.VarChar(50)
  created_at  DateTime?    @default(now()) @db.Timestamp(6)
  is_active   Boolean?     @default(true)
  users       users        @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  habit_logs  habit_logs[]
}

model habit_logs {
  habit_log_id Int      @id @default(autoincrement())
  user_id      Int
  habit_id     Int
  completed    Boolean? @default(false)
  date         DateTime @db.Date
  note         String?
  users        users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  habits       habits   @relation(fields: [habit_id], references: [habit_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([habit_id, date])
}

model goals {
  goal_id      Int         @id @default(autoincrement())
  user_id      Int
  name         String      @db.VarChar(255)
  description  String?
  target_value Decimal?    @db.Decimal(10, 2)
  deadline     DateTime?   @db.Date
  users        users       @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  goal_logs    goal_logs[]
}

model goal_logs {
  goal_log_id   Int      @id @default(autoincrement())
  user_id       Int
  goal_id       Int
  current_value Decimal? @db.Decimal(10, 2)
  date          DateTime @db.Date
  note          String?
  users         users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  goals         goals    @relation(fields: [goal_id], references: [goal_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([goal_id, date])
}
